# ---------------------------------------------------------
#  ENTORNO GENERAL DEL PROYECTO
# ---------------------------------------------------------
APP_NAME=DepoComUHO
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ---------------------------------------------------------
#  BASE DE DATOS (POSTGRESQL)
# ---------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=depocom
DB_USERNAME=depocom_user
DB_PASSWORD=depocom_pass

# ---------------------------------------------------------
#  FRONTEND
# ---------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------
#  AUTENTICACIÓN (FUTURA INTEGRACIÓN UHO)
# ---------------------------------------------------------
AUTH_UHO_CLIENT_ID=
AUTH_UHO_CLIENT_SECRET=
AUTH_UHO_REDIRECT_URI=http://localhost:8000/auth/callback
